# Local SQLite (default — zero config)
DATABASE_URL=./taskflow.db

# Better Auth
BETTER_AUTH_SECRET=generate-a-32-char-random-string-here
BETTER_AUTH_URL=http://localhost:3000

# Optional: Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Production PostgreSQL (Neon) — replace DATABASE_URL and switch dialect in drizzle.config.ts
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.neon.tech/taskflow?sslmode=require
